{
  "version": "0.2.0",
  "schema_version": "v020_fixture_manifest_1",
  "description": "Source-based postflop fixture lab manifest for PokerVision_Solver_AllPreflop_Flop.",
  "purpose": "Track postflop source JSON cases before source discovery, contracts, normalizer, player resolver, ranges, equity, or poker decisions are implemented.",
  "allowed_source_types": [
    "dark_json",
    "pending_json",
    "service_json",
    "current_cycle_json",
    "runtime_json",
    "solver_payload_json",
    "final_clear_json",
    "manual_live_like_json",
    "unknown"
  ],
  "required_case_fields": [
    "case_id",
    "description",
    "source_type",
    "source_file",
    "expected_file",
    "normalized_file",
    "street_candidate",
    "pot_type_candidate",
    "is_real_project_source",
    "is_manual_live_like_source",
    "source_of_truth_note",
    "requires_click_cycle",
    "status",
    "notes"
  ],
  "rules": {
    "final_clear_json_required": false,
    "manual_live_like_json_must_be_marked": true,
    "expected_json_contains_poker_decision": false,
    "normalized_file_required_to_exist_before_normalizer": false,
    "source_file_required_to_exist": true,
    "expected_file_required_to_exist": true,
    "duplicate_case_id_allowed": false
  },
  "cases": [
    {
      "case_id": "flop_source_case_001",
      "description": "Minimal manual live-like flop dark_json source case for future postflop normalizer tests. No poker decision is included.",
      "source_type": "dark_json",
      "source_file": "source_json/dark_json/flop_source_case_001.dark.json",
      "expected_file": "expected/flop_source_case_001.expected.json",
      "normalized_file": "normalized/flop_source_case_001.normalized.json",
      "street_candidate": "flop",
      "pot_type_candidate": "single_raised_pot_candidate",
      "is_real_project_source": false,
      "is_manual_live_like_source": true,
      "source_of_truth_note": "Manual live-like dark_json fixture created for V0.2.3. It is not claimed to be a real exported PokerVision live source.",
      "requires_click_cycle": false,
      "status": "active",
      "notes": [
        "First source-based postflop fixture case.",
        "Final Clear_JSON is intentionally not required.",
        "Used only to validate fixture lab storage rules before source discovery, contracts, or normalizer are implemented."
      ]
    }
  ]
}
